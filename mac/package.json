{
  "name": "3nweb",
  "version": "0.28.34",
  "private": true,
  "description": "3NWeb platform client for desktop environments",
  "main": "build/all/main.js",
  "scripts": {
    "postinstall": "bash packing/patch-type-files.sh && bash -c \"rm -rf node_modules/browserify/node_modules/buffer\" && bash packing/npm-ci-test-apps.sh && bash packing/npm-ci-native-modules.sh",
    "compile": "bash packing/compile.sh",
    "compile-all": "npm run compile all",
    "tests": "bash build/test-apps/run-tests-on.sh",
    "start-app": "electron build/all/main.js --data-dir=3NWeb-data --devtools --console-log-http --allow-multi-instances",
    "build": "bash packing/build.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PrivacySafe/privacysafe-platform-electron"
  },
  "keywords": [
    "3NWeb",
    "desktop",
    "client",
    "ASMail",
    "MailerId",
    "3NStorage"
  ],
  "author": {
    "name": "3NSoft Inc.",
    "url": "https://3nsoft.com",
    "email": "hq@3nsoft.com"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@types/semver": "^7.5.8",
    "adm-zip": "^0.5.16",
    "command-line-args": "^5.2.1",
    "command-line-usage": "^6.1.3",
    "core-3nweb-client-lib": "^0.44.11",
    "electron-builder-sandbox-fix": "^1.1.1",
    "electron-localshortcut": "^3.2.1",
    "electron-updater": "^6.7.3",
    "mac-screen-capture-permissions": "^2.1.0",
    "mime": "^1.3.4",
    "portfinder": "^1.0.38",
    "protobufjs": "^6.11.4",
    "punycode": "^2.1.1",
    "rxjs": "^7.8.2",
    "semver": "^7.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/punycode": "^2.1.1",
    "browserify": "^17.0.1",
    "buffer": "^4.9.2",
    "electron": "^40.0.0",
    "electron-build-env": "^0.2.0",
    "electron-builder": "^24.13.3",
    "js-yaml": "^4.1.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  }
}